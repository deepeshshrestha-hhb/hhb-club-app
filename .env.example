# Copy this file to .env and fill in the real values.
# The .env file is gitignored and must never be committed or synced in plaintext.

# Flask session signing key. Generate a random one, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Spond login credentials for the account that manages your club's group.
SPOND_USERNAME=your_email@example.com
SPOND_PASSWORD=your_spond_password

# Your club's Spond Group ID. Find it in the web app URL:
#   spond.com/client/group/<GROUP_ID>/...
SPOND_GROUP_ID=your_group_id
