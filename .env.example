# Copy this file to .env and fill in the real values.
# The .env file is gitignored and must never be committed or synced in plaintext.

# Flask session signing key. Generate a random one, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Spond login credentials for the account that manages your club's group.
SPOND_USERNAME=your_email@example.com
SPOND_PASSWORD=your_spond_password

# Your club's Spond Group ID. Find it in the web app URL:
#   spond.com/client/group/<GROUP_ID>/...
SPOND_GROUP_ID=your_group_id

# --- Cloudflare R2 durable storage (production / Render) ---
# Leave these blank for local development: with no R2_* values set, the app
# simply reads/writes the local data/ and tournaments/ folders as before.
# When all four are set, on startup the app downloads the canonical files from
# R2 and re-uploads any file it writes (backing up the prior version under a
# backups/ prefix before each overwrite).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com

# Admin login (single user) protecting the /admin/* routes. Both must be set
# for the Admin area to be reachable.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# --- Claude AI assist (optional) ---
# Enables the admin "Summarize / Rewrite / change tone" buttons on event
# summaries. Leave blank to disable the AI helpers (the summary field still
# works as a plain editable text box). Get a key at console.anthropic.com.
# ANTHROPIC_MODEL is optional; omit it to use the fast, low-cost default.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
